# Telegram bot token from @BotFather
BOT_TOKEN=123456:change-me

# Public HTTPS origin for Telegram WebApp and rendered image URLs.
# In local dev use a tunnel, e.g. https://example.ngrok-free.app
PUBLIC_BASE_URL=https://your-domain.example

# Local webapp server
HOST=0.0.0.0
PORT=8080

RENDERED_DIR=.cache/rendered
# When rendered cards exceed this size, oldest files are deleted down to ~90% of the limit.
RENDERED_MAX_MB=256
