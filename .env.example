# Create a bot with @BotFather. Never commit a real token.
BOT_TOKEN=123456789:replace-with-your-bot-token
# Public HTTPS origin that Telegram opens as the WebApp.
PUBLIC_BASE_URL=https://cards.example.com
# Private storage chat/channel ID (usually starts with -100); grant the bot Send Messages.
STORAGE_CHAT_ID=-1001234567890

HOST=0.0.0.0
PORT=8080
RENDERED_DIR=.cache/rendered
RENDERED_MAX_MB=256
# Per authenticated Telegram user; bounds storage-chat and metadata abuse.
RENDERED_UPLOADS_PER_HOUR=30
SEARCH_CACHE_TTL=300
WEBAPP_AUTH_MAX_AGE=86400
# Used for Telegram Bot API, Tenrai and the AniList image CDN.
# PROXY_URL=http://host.docker.internal:7890
